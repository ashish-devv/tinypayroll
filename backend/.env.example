# Copy to .env (gitignored) for local dev overrides. Values below are placeholders — dev
# profile already has safe fallbacks (see application-dev.yml), so .env is optional locally.
# All of these are REQUIRED (no defaults) when running with SPRING_PROFILES_ACTIVE=prod.

SPRING_PROFILES_ACTIVE=dev

DB_URL=jdbc:postgresql://localhost:5432/tinypayroll
DB_USERNAME=postgres
DB_PASSWORD=

# openssl rand -base64 48
JWT_SECRET=

# openssl rand -base64 32   (must decode to exactly 32 bytes — AES-256)
BANK_ENCRYPTION_KEY=

CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

PORT=8080
